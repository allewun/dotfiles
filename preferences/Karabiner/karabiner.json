        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Map Shift+Shift to Shift+F2 in Firefox (No Interruptions)",
                        "enabled": false,
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "name": "left_shift_pressed",
                                        "type": "variable_if",
                                        "value": 1
                                    },
                                    {
                                        "bundle_identifiers": [
                                            "org.mozilla.firefox"
                                        ],
                                        "type": "frontmost_application_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "left_shift",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "parameters": { "basic.to_if_alone_timeout_milliseconds": 500 },
                                "to": [{ "key_code": "left_shift" }],
                                "to_if_alone": [
                                    {
                                        "key_code": "f2",
                                        "modifiers": ["shift", "fn"]
                                    },
                                    {
                                        "set_variable": {
                                            "name": "left_shift_pressed",
                                            "value": 0
                                        }
                                    }
                                ],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "left_shift",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "parameters": {
                                    "basic.to_delayed_action_delay_milliseconds": 500,
                                    "basic.to_if_alone_timeout_milliseconds": 500
                                },
                                "to": [{ "key_code": "left_shift" }],
                                "to_delayed_action": {
                                    "to_if_canceled": [
                                        {
                                            "set_variable": {
                                                "name": "left_shift_pressed",
                                                "value": 0
                                            }
                                        }
                                    ],
                                    "to_if_invoked": [
                                        {
                                            "set_variable": {
                                                "name": "left_shift_pressed",
                                                "value": 0
                                            }
                                        }
                                    ]
                                },
                                "to_if_alone": [
                                    {
                                        "set_variable": {
                                            "name": "left_shift_pressed",
                                            "value": 1
                                        }
                                    },
                                    { "key_code": "left_shift" }
                                ],
                                "type": "basic"
                            }
                        ]
